# Copy to `.env` in the repo root (optional). Vite loads this for local dev.

# --- Render / production static build ---
# In this repo, `render.yaml` sets VITE_API_BASE_URL for the static site automatically.
# Override locally only if your API is not at https://littlebuggy-api.onrender.com
# VITE_API_BASE_URL=https://littlebuggy-api.onrender.com

# Leave UNSET for normal local dev: Vite proxies /api, /wait-times, /virus-trends → 127.0.0.1:8000.

# --- Local proxy override (optional) ---
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Homepage snapshot file: public/data/homepage-summary.json (npm run weekly:homepage).
# VITE_DEBUG_API=true
