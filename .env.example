# Copy to `.env` for local overrides (optional). Vite loads this automatically.

# Production / Render static build: full URL of the FastAPI service, no trailing slash.
# Example: https://littlebuggy-api.onrender.com
# Leave unset locally so `/api` is proxied to the backend (see vite.config.js).
# For the /admin/update page against a hosted API, set the full API origin (no trailing slash):
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_API_BASE_URL=

# Homepage loads `public/data/homepage-summary.json` (weekly: npm run weekly:homepage).
# Script deps only: pip install -r scripts/requirements-homepage.txt (httpx; no SQLAlchemy).

# Set to `true` to log the homepage summary URL in the browser console (build-time env).
# VITE_DEBUG_API=true

# Optional: where the dev server should proxy /api (default http://127.0.0.1:8000)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
