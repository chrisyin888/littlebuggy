# Copy to `backend/.env` for local development.

# Default in code is sqlite:///./littlebuggy.db when unset (relative to process cwd — use `backend/` as cwd).
# DATABASE_URL=sqlite:///./littlebuggy.db

# Render / production PostgreSQL (use Internal Database URL from Render).
# Use the SAME DATABASE_URL on the API web service and every Cron job so jobs and /api/homepage-summary share one database.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/littlebuggy

# Browser origins allowed to call the API (comma-separated, no spaces), or * for any origin.
# Production example (replace with your static site URL):
# CORS_ORIGINS=https://littlebuggy-web.onrender.com
# CORS_ORIGINS=*

# --- Admin: regenerate static homepage JSON (optional) ---
# Long random secret; required header: X-Admin-Token on POST /api/admin/homepage-snapshot/regenerate
# Leave unset to disable the endpoint (returns 503).
# ADMIN_HOMEPAGE_TOKEN=

# If set, the regenerate endpoint also writes this file (API process must have write permission).
# From backend/ cwd, typical repo-relative path:
# HOMEPAGE_SUMMARY_OUTPUT_PATH=../public/data/homepage-summary.json
# HOMEPAGE_SUMMARY_OUTPUT_PATH=

# --- Render cron only: public API base URL for POST /api/admin/virus-trends/refresh (see render.yaml) ---
# LITTLEBUGGY_API_URL=https://your-api.onrender.com
