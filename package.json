{
  "name": "littlebuggy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "bash -c 'cd backend && source .venv/bin/activate && exec python3 -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload'",
    "dev:all": "concurrently --kill-others-on-fail -n api,vite -c cyan,magenta \"npm run dev:api\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "update:homepage-summary": "python3 scripts/update_homepage_summary.py",
    "weekly:homepage": "python3 scripts/update_homepage_summary.py",
    "weekly:homepage:check": "python3 scripts/check_homepage_summary.py"
  },
  "dependencies": {
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.0",
    "vite": "^8.0.1"
  }
}
